{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/1password/refs/heads/main/json-schema/1password-events-token-introspection-schema.json",
  "title": "TokenIntrospection",
  "description": "Information about the bearer token used for authentication.",
  "type": "object",
  "properties": {
    "uuid": {
      "type": "string",
      "format": "uuid",
      "description": "The unique identifier of the token."
    },
    "features": {
      "type": "array",
      "description": "The features and permissions the token has access to.",
      "items": {
        "type": "string",
        "enum": [
          "signinattempts",
          "itemusages",
          "auditevents"
        ]
      }
    }
  }
}