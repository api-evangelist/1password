{
  "info": {
    "_postman_id": "e94334fb-db60-453b-9aa5-3c4ab974442e",
    "name": "1Password Events API",
    "description": "The 1Password Events API provides programmatic access to event data generated within a 1Password account. It enables security teams and administrators to retrieve sign-in attempts, item usage records, and audit events for monitoring, compliance, and security analysis. The API uses cursor-based pagination with POST requests to efficiently stream large volumes of event data.\n\nContact Support:\n Name: 1Password Support",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "createdAt": "2026-06-05T15:02:30.000Z",
